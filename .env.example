# Copy this file to .env.local and fill in the values.
# .env.local is gitignored.

# Flask
SECRET_KEY=change-me
AUTHLIB_INSECURE_TRANSPORT=1   # allow OAuth on http://localhost (dev only)

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_ALLOWED_DOMAIN=example.org

# GCP
GCP_PROJECT_ID=my-project
GCP_SA_FILE=./key.json
REPORT_BUCKET=my-test-reports
CC_REPORT_PREFIX=my-app/TestReport/
API_KEY=change-me

# Postgres
POSTGRES_DB=buildportal
POSTGRES_USER=buildportal
POSTGRES_PASSWORD=change-me

# Optional: AWS / S3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_SOURCES=bucketA:path/;bucketB:path/

# Optional: Crash Logs
# CRASH_LOGS_BUCKET=my-crash-logs
# CRASH_LOGS_PREFIX=crash-logs/

# Optional: Rancher integration
# RANCHER_BASE_URL=https://rancher.example.com
# RANCHER_CLUSTER_IDS=dev:cluster-id,prod:cluster-id

# Optional: Jenkins Deploy-Quest
# JENKINS_URL=https://jenkins.example.com
# JENKINS_DEPLOY_TOKEN=change-me
